<view class="page">
  <view wx:if="{{loading}}" class="state">加载中...</view>

  <view wx:elif="{{error}}" class="state state-error">
    <text>{{error}}</text>
  </view>

  <view wx:else class="content">
    <view class="summary">
      <view class="status">{{statusText}}</view>
      <view class="amount">{{amountText}}</view>
      <view class="order-no">订单号 {{order.orderNo}}</view>
    </view>

    <view class="section">
      <view class="section-title">商品</view>
      <view wx:for="{{items}}" wx:key="productId" class="item-row">
        <view class="item-main">
          <view class="item-name">{{item.name}}</view>
          <view wx:if="{{item.spec}}" class="item-spec">{{item.spec}}</view>
        </view>
        <view class="item-side">
          <view>{{item.subtotalText}}</view>
          <view class="quantity">x{{item.quantity}}</view>
        </view>
      </view>
    </view>

    <view class="section">
      <view class="section-title">收货信息</view>
      <view class="info-row">
        <text class="info-label">收货人</text>
        <text>{{order.receiverName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">手机号</text>
        <text>{{order.receiverPhone}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">地址</text>
        <text>{{order.receiverAddress}}</text>
      </view>
      <view wx:if="{{order.remark}}" class="info-row">
        <text class="info-label">备注</text>
        <text>{{order.remark}}</text>
      </view>
    </view>
  </view>
</view>
