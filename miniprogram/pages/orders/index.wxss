.page {
  min-height: 100vh;
  background: #f6f8fb;
  color: #1f2933;
}

.order-list {
  padding: 28rpx;
}

.order-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 35, 52, 0.06);
}

.order-main {
  flex: 1;
  min-width: 0;
}

.order-no {
  font-size: 28rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #102a43;
}

.status,
.open-text {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #52606d;
}

.order-side {
  min-width: 140rpx;
  text-align: right;
}

.amount {
  font-size: 30rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #d64545;
}

.state {
  min-height: 70vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  color: #52606d;
  font-size: 28rpx;
}

.state-error {
  color: #d64545;
}
