<view class="page">
  <view wx:if="{{loading}}" class="state">加载中...</view>

  <view wx:elif="{{error}}" class="state state-error">
    <text>{{error}}</text>
  </view>

  <view wx:elif="{{orders.length}}" class="order-list">
    <view wx:for="{{orders}}" wx:key="_id" class="order-card" data-id="{{item._id}}" bindtap="openOrder">
      <view class="order-main">
        <view class="order-no">{{item.orderNo}}</view>
        <view class="status">{{item.statusText}}</view>
      </view>
      <view class="order-side">
        <view class="amount">{{item.amountText}}</view>
        <view class="open-text">查看</view>
      </view>
    </view>
  </view>

  <view wx:else class="state">
    <text>暂无订单</text>
  </view>
</view>
