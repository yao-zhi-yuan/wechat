<view class="page">
  <view wx:if="{{loading}}" class="state">加载中...</view>

  <view wx:elif="{{error && !order}}" class="state state-error">
    <text>{{error}}</text>
  </view>

  <view wx:else class="content">
    <view wx:if="{{error}}" class="error-banner">{{error}}</view>

    <view class="section">
      <view class="section-title">订单信息</view>
      <view class="row">
        <text class="label">订单号</text>
        <text class="value">{{order.orderNo}}</text>
      </view>
      <view class="row">
        <text class="label">状态</text>
        <text class="value">{{order.statusText}}</text>
      </view>
      <view class="row">
        <text class="label">发货同步</text>
        <text class="value">{{order.shippingStatusText}}</text>
      </view>
      <view wx:if="{{order.shippingHelpText}}" class="warning">{{order.shippingHelpText}}</view>
      <view wx:if="{{order.wechatShippingError}}" class="warning">{{order.wechatShippingError}}</view>
    </view>

    <view class="section">
      <view class="section-title">收货信息</view>
      <view class="row">
        <text class="label">收货人</text>
        <text class="value">{{order.receiverName}}</text>
      </view>
      <view class="row">
        <text class="label">手机号</text>
        <text class="value">{{order.receiverPhone}}</text>
      </view>
      <view class="address">{{order.receiverAddress}}</view>
      <view wx:if="{{order.remark}}" class="remark">备注：{{order.remark}}</view>
    </view>

    <view class="section">
      <view class="section-title">商品</view>
      <view wx:for="{{items}}" wx:key="productId" class="item-row">
        <view class="item-main">
          <view class="item-name">{{item.name}}</view>
          <view class="item-spec">{{item.spec}}</view>
        </view>
        <view class="item-side">
          <view>{{item.priceText}} x {{item.quantity}}</view>
          <view class="subtotal">{{item.subtotalText}}</view>
        </view>
      </view>
      <view class="total-row">
        <text>实付</text>
        <text>{{order.amountText}}</text>
      </view>
    </view>

    <view class="actions">
      <button wx:if="{{order.canStartDelivery}}" class="action-button primary" loading="{{operating}}" disabled="{{operating}}" bindtap="startDelivery">开始配送</button>
      <button wx:if="{{order.canComplete}}" class="action-button primary" loading="{{operating}}" disabled="{{operating}}" bindtap="completeOrder">完成订单</button>
      <button wx:if="{{order.canRefund}}" class="action-button danger" loading="{{operating}}" disabled="{{operating}}" bindtap="requestRefund">申请退款</button>
    </view>
  </view>
</view>
