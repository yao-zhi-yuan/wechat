.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
  background: #f6f8fb;
  color: #1f2933;
}

.header {
  margin-bottom: 28rpx;
}

.title {
  font-size: 42rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #102a43;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #52606d;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.metric {
  padding: 28rpx;
  border-radius: 8rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 35, 52, 0.06);
}

.metric-value {
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #102a43;
}

.metric-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #52606d;
}

.action-button {
  height: 88rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #ffffff;
  color: #102a43;
  font-size: 30rpx;
  line-height: 88rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 35, 52, 0.06);
}

.action-button.primary {
  background: #1d4e89;
  color: #ffffff;
}

.action-button::after {
  border: 0;
}

.state {
  min-height: 55vh;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #52606d;
  font-size: 28rpx;
}

.state-error {
  color: #d64545;
}
